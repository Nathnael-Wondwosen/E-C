# Shared environment variables example for the current deployment topology

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.example.com/database?appName=App
MONGO_URI=mongodb+srv://admin:admin123@cluster0.rcuwrqi.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=ecommerce_platform

# Authentication
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_strong_password
GOOGLE_CLIENT_ID=your_google_web_client_id
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_web_client_id
EXPOSE_PASSWORD_RESET_TOKEN=true

# Service integration
CORS_ORIGIN=http://localhost:3005,http://localhost:3006
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
IDENTITY_SERVICE_URL=http://localhost:3015
ENFORCE_IDENTITY_BOUNDARY=true
IDENTITY_SERVICE_PORT=3015

# Optional frontend tuning
NEXT_PUBLIC_ALLOW_MOCK_FALLBACKS=false
NEXT_PUBLIC_HTTP_TIMEOUT_MS=7000
NEXT_PUBLIC_HTTP_RETRIES=1

# Optional uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_URL=cloudinary://your_cloudinary_api_key:your_cloudinary_api_secret@your_cloudinary_cloud_name

# Optional search
ALGOLIA_APP_ID=your_algolia_app_id
ALGOLIA_SEARCH_KEY=your_algolia_search_key

# Local gateway port
PORT=3000
