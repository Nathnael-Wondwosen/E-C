# Customer Portal Environment Variables Example

# Cloudinary Configuration
CLOUDINARY_URL=cloudinary://your_cloudinary_api_key:your_cloudinary_api_secret@your_cloudinary_cloud_name
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# API Gateway URL (for local development)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Optional fallback: frontend can also read Google client id from API Gateway
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_web_client_id

# For Render deployment, this will be set by the render.yaml configuration
# NEXT_PUBLIC_API_BASE_URL will be automatically set to the API Gateway URL
