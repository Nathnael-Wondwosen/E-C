# API Gateway Environment Variables Example

# Required
PORT=3000
MONGODB_URI=mongodb+srv://username:password@cluster.example.com/database?appName=App
MONGODB_DB_NAME=ecommerce_platform
JWT_SECRET=replace_with_a_long_random_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_strong_password

# Recommended
CORS_ORIGIN=http://localhost:3005,http://localhost:3006
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your_google_web_client_id
EXPOSE_PASSWORD_RESET_TOKEN=true
IDENTITY_SERVICE_URL=http://localhost:3015
ENFORCE_IDENTITY_BOUNDARY=true

# Optional uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Optional operational tuning
RATE_LIMIT_PER_MINUTE=300
REDIS_URL=
